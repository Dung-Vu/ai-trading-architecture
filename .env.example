# ===========================================
# Exchange API Keys
# ===========================================
# Binance Mainnet
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Testnet (get from https://testnet.binance.vision/)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ===========================================
# LLM Providers (for Phase 2+ AI Debate)
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MODEL=anthropic/claude-sonnet-4
LITELLM_FALLBACK_MODEL=openai/gpt-4o
DSPY_DEFAULT_MODEL=anthropic/claude-sonnet-4
DEBATE_MAX_ROUNDS=3
DEBATE_TEMPERATURE=0.7
DEBATE_MAX_TOKENS=4096
DEBATE_TIMEOUT_SECONDS=120
DEBATE_RESULT_CACHE_TTL_SECONDS=30
DEBATE_RESULT_CACHE_MAX_ENTRIES=128
LLM_MAX_RETRIES=3
LLM_CACHE_TTL_SECONDS=30
LLM_CACHE_MAX_ENTRIES=256
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RESET_SECONDS=60

# ===========================================
# Database Connections
# ===========================================
# QuestDB (ILP for writes)
QUESTDB_ILP_ADDR=localhost:9009
QUESTDB_HTTP_ADDR=localhost:9000

# QuestDB (PostgreSQL wire protocol for queries)
QUESTDB_PG_HOST=localhost
QUESTDB_PG_PORT=8812
QUESTDB_PG_USER=admin
QUESTDB_PG_PASSWORD=quest

# PostgreSQL (audit + analytics)
DATABASE_URL=postgresql://trading_user:trading_pass@localhost:5432/trading_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=86400

# Qdrant (vector store for Mem0)
QDRANT_URL=http://localhost:6333
MEM0_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEM0_LLM_MODEL=gpt-4o-mini

# ===========================================
# Monitoring
# ===========================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LOG_LEVEL=INFO
LOG_APP_NAME=trading
LOG_ERROR_NAME=error
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_ERROR_RETENTION=90 days

# Weights & Biases (ML tracking)
WANDB_PROJECT=ai-trading-architecture
WANDB_API_KEY=

# ===========================================
# Trading Configuration
# ===========================================
# Mode: dryrun, testnet, live
TRADING_MODE=dryrun
EXCHANGE_NAME=binance

# Initial capital for backtesting/dry-run
INITIAL_CAPITAL=10000
LOOP_INTERVAL_SECONDS=60

# Risk settings
MAX_DAILY_LOSS_PCT=3.0
MAX_DRAWDOWN_PCT=10.0
MAX_POSITION_PCT=20.0
MAX_LEVERAGE=3
DEFAULT_QUANTITY_PCT=0.10
POSITION_SIZER_RISK_PCT=0.02

# Symbols to trade
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
SIMULATED_BASE_PRICES={"BTC/USDT":67500.0,"ETH/USDT":3450.0,"SOL/USDT":145.0,"XRP/USDT":0.52,"ADA/USDT":0.45}

# Strategy parameters
STRATEGY_SMA_FAST=20
STRATEGY_SMA_SLOW=50
STRATEGY_RSI_PERIOD=14
STRATEGY_RSI_OVERBOUGHT=70
STRATEGY_RSI_OVERSOLD=30
BBANDS_STOP_LOSS_PCT=0.02

# ===========================================
# Data Pipeline
# ===========================================
DATA_TESTNET=true
DATA_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT
DATA_CHANNELS=TRADES,CANDLES,TICKER
DATA_CANDLE_INTERVAL=1m
# Data pipeline reuses REDIS_URL and QUESTDB_HTTP_ADDR above.
DATA_MAX_LATENCY_MS=5000
DATA_Z_SCORE_THRESHOLD=3.0
DATA_MAX_SPREAD_PCT=1.0

# ===========================================
# News / Sentiment
# ===========================================
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_API_URL=https://cryptopanic.com/api/v1/posts/
NEWS_RSS_FEEDS={"CoinDesk":"https://www.coindesk.com/arc/outboundfeeds/rss/","CoinTelegraph":"https://cointelegraph.com/rss","CryptoNews":"https://cryptonews.com/news/feed/"}

# ===========================================
# Memory / Persistence
# ===========================================
PG_POOL_MIN_SIZE=2
PG_POOL_MAX_SIZE=10
PG_POOL_COMMAND_TIMEOUT=30
KNOWLEDGE_GRAPH_TOP_N=5
KNOWLEDGE_GRAPH_MIN_OCCURRENCES=3

# ===========================================
# Auto-Tuning / Optimization
# ===========================================
AUTOTUNE_MIN_TRADES=20
AUTOTUNE_SHARPE_DECAY_THRESHOLD=0.5
AUTOTUNE_WIN_RATE_DECAY_THRESHOLD=0.40
AUTOTUNE_DRAWDOWN_ALERT_THRESHOLD=0.15
AUTOTUNE_PARAM_RANGES={"sma_fast":{"min":5,"max":50,"default":20},"sma_slow":{"min":20,"max":200,"default":50},"rsi_period":{"min":7,"max":21,"default":14},"rsi_overbought":{"min":65,"max":80,"default":70},"rsi_oversold":{"min":20,"max":35,"default":30}}
AUTOTUNE_PARAM_COMBOS=[{"sma_fast":10,"sma_slow":30,"rsi_oversold":35,"rsi_overbought":65},{"sma_fast":15,"sma_slow":40,"rsi_oversold":32,"rsi_overbought":68},{"sma_fast":20,"sma_slow":50,"rsi_oversold":30,"rsi_overbought":70},{"sma_fast":25,"sma_slow":60,"rsi_oversold":28,"rsi_overbought":72},{"sma_fast":10,"sma_slow":40,"rsi_oversold":30,"rsi_overbought":75},{"sma_fast":15,"sma_slow":50,"rsi_oversold":35,"rsi_overbought":70}]
OPTIMIZER_SMA_PARAM_SPACE={"sma_fast":[10,50],"sma_slow":[40,200],"rsi_period":[7,21],"rsi_overbought":[60,80],"rsi_oversold":[20,40]}
OPTIMIZER_BBANDS_PARAM_SPACE={"bb_period":[10,40],"bb_std_dev":[1.5,3.0],"volume_factor":[1.0,2.5]}
